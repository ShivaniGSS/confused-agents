# Copy to .env and fill in keys before running experiments.
# .env is gitignored. Never commit real keys.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
TOGETHER_API_KEY=

# Model selectors. Defaults below match the paper.
FRONTIER_MODEL=claude-sonnet-4-6
OPEN_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
PROVIDER=anthropic   # one of: anthropic, openai, together

# Mock MCP server SQLite paths (one DB per server).
MOCK_GMAIL_DB=./.state/gmail.sqlite
MOCK_CALENDAR_DB=./.state/calendar.sqlite
MOCK_DRIVE_DB=./.state/drive.sqlite
MOCK_PAYMENTS_DB=./.state/payments.sqlite

# Mock MCP server bind addresses.
MOCK_GMAIL_ADDR=127.0.0.1:18081
MOCK_CALENDAR_ADDR=127.0.0.1:18082
MOCK_DRIVE_ADDR=127.0.0.1:18083
MOCK_PAYMENTS_ADDR=127.0.0.1:18084

# CapGuard proxy.
CAPGUARD_ADDR=127.0.0.1:18090

# Results directory.
RESULTS_DIR=./results
LLM_CACHE_DIR=./results/llm_cache
