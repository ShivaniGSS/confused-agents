{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/confused-agents/scenario_metadata.schema.json",
  "title": "Observability scenario",
  "type": "object",
  "required": ["id", "axis", "principals", "capability", "approved_tools", "turns"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "axis": { "type": "string", "pattern": "^[A-Ha-h]$" },
    "axis_param": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "value": { "type": "string" }
      }
    },
    "principals": {
      "type": "object",
      "required": ["invoking"],
      "properties": {
        "invoking": { "type": "string" }
      }
    },
    "capability": {
      "type": "object",
      "required": ["purpose"],
      "properties": {
        "purpose": { "type": "string" }
      }
    },
    "approved_tools": {
      "type": "array",
      "items": { "type": "string" }
    },
    "attacker_strategy": { "type": "string" },
    "attacker_budget": { "type": "integer", "minimum": 0 },
    "elicitation": {
      "type": "object",
      "description": "Optional notes when live LLM runs often refuse or omit tools; optional strength for stratified reporting.",
      "additionalProperties": true,
      "properties": {
        "strength": {
          "type": "string",
          "enum": ["strong", "medium", "weak"],
          "description": "How fully user_prompt pins ids/recipients; use for stratified tables."
        },
        "live_llm_profile": { "type": "string" },
        "paper_note": { "type": "string" }
      }
    },
    "metric_decomposition": {
      "type": "object",
      "description": "Optional split of distinct evaluation claims (e.g. axis H injection vs routing).",
      "additionalProperties": true
    },
    "turns": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/turn" }
    },
    "benign_turns": {
      "type": "array",
      "items": { "$ref": "#/$defs/turn" }
    }
  },
  "$defs": {
    "toolCall": {
      "type": "object",
      "required": ["tool", "arguments"],
      "properties": {
        "tool": { "type": "string" },
        "arguments": { "type": "object" },
        "target_subject": { "type": "string" },
        "violation": { "type": "boolean" }
      }
    },
    "turn": {
      "type": "object",
      "required": ["turn"],
      "properties": {
        "turn": { "type": "integer" },
        "agent_reasoning": { "type": "string" },
        "user_prompt": { "type": "string" },
        "tool_calls": {
          "type": "array",
          "items": { "$ref": "#/$defs/toolCall" }
        },
        "metadata": { "type": "object" }
      }
    }
  }
}
